{
  "name": "jotlang",
  "version": "0.6.0",
  "description": "JOTLANG — Jot Object Template Language. Compile .jot files to HTML (static compiler + CLI). \"JOTL\" for short.",
  "keywords": [
    "jotlang",
    "jotl",
    "markup",
    "compiler",
    "html",
    "template"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "jotlang": "dist/jotl.mjs"
  },
  "files": [
    "dist/",
    "styles/",
    "README.md",
    "scripts/prepare-cli.mjs",
    "scripts/bundle-styles.mjs"
  ],
  "scripts": {
    "dev": "vite src/playground",
    "build": "npm run build:lib && npm run build:cli",
    "build:lib": "esbuild src/index.ts --bundle --platform=neutral --format=esm --outfile=dist/index.js --external:chokidar --external:peggy && tsc -p tsconfig.build.json",
    "build:styles": "node scripts/bundle-styles.mjs",
    "prebuild:cli": "npm run build:styles",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/jotl.mjs",
    "build:playground": "vite build src/playground --outDir ../../dist/playground",
    "prepare": "node scripts/prepare-cli.mjs",
    "prepack": "npm run build:styles && npm run build:lib && npm run build:cli",
    "pretest": "npm run build:styles && npm run build:lib",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thaumonaut/jotl-project.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/Thaumonaut/jotl-project#readme",
  "bugs": {
    "url": "https://github.com/Thaumonaut/jotl-project/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "peggy": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
