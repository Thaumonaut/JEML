{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JOTL",
  "scopeName": "source.jotlang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#script-directive"
    },
    {
      "include": "#style-directive"
    },
    {
      "include": "#props-directive"
    },
    {
      "include": "#component-directive"
    },
    {
      "include": "#directive-close"
    },
    {
      "include": "#directive-open"
    },
    {
      "include": "#void-element"
    },
    {
      "include": "#inline-element"
    },
    {
      "include": "#control-flow-close"
    },
    {
      "include": "#control-flow"
    },
    {
      "include": "#block-close"
    },
    {
      "include": "#block-open"
    },
    {
      "include": "#fenced-code"
    },
    {
      "include": "#sibling-marker"
    },
    {
      "include": "#content-line"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.jotlang",
          "begin": "%\\{",
          "end": "%\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.jotlang"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.jotlang"
            }
          }
        },
        {
          "name": "comment.line.percent.jotlang",
          "begin": "%",
          "end": "$",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.jotlang"
            }
          }
        }
      ]
    },
    "script-directive": {
      "comment": "Embed TypeScript/JavaScript highlighting inside >> script [...] : { ... } <<. The opening brace must be the last non-whitespace on its line. The closing brace must be at column 0 (unindented) \u2014 script bodies are always indented, so a }-at-column-0 is unambiguously the script's close.",
      "begin": "^(\\s*)(>>)\\s+(script)\\b([^:\\n]*?)(:)\\s*(\\{)\\s*$",
      "end": "^(\\})\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.directive.jotlang"
        },
        "3": {
          "name": "entity.name.tag.jotlang"
        },
        "4": {
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        },
        "5": {
          "name": "punctuation.separator.content.jotlang"
        },
        "6": {
          "name": "punctuation.section.embedded.begin.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.jotlang"
        }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "style-directive": {
      "comment": "Embed CSS highlighting inside >> style [type=css]: { ... } <<. Same constraint as script-directive \u2014 the closing } must be at column 0.",
      "begin": "^(\\s*)(>>)\\s+(style)\\b([^:\\n]*?)(:)\\s*(\\{)\\s*$",
      "end": "^(\\})\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.directive.jotlang"
        },
        "3": {
          "name": "entity.name.tag.jotlang"
        },
        "4": {
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        },
        "5": {
          "name": "punctuation.separator.content.jotlang"
        },
        "6": {
          "name": "punctuation.section.embedded.begin.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.jotlang"
        }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "props-directive": {
      "comment": "Embed TypeScript highlighting inside >> props: { ... } <<. Same closing-brace-at-column-0 rule as script-directive. Used by solid-jotlang to declare a component's typed props.",
      "begin": "^(\\s*)(>>)\\s+(props)\\b([^:\\n]*?)(:)\\s*(\\{)\\s*$",
      "end": "^\\s*(\\})\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.directive.jotlang"
        },
        "3": {
          "name": "entity.name.tag.jotlang"
        },
        "4": {
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        },
        "5": {
          "name": "punctuation.separator.content.jotlang"
        },
        "6": {
          "name": "punctuation.section.embedded.begin.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.jotlang"
        }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "component-directive": {
      "comment": "solid-jotlang component declaration: >> component Name [...] : ... << component. The Name is highlighted as a class entity.",
      "match": "^(\\s*)(>>)\\s+(component)\\s+([A-Z][a-zA-Z0-9_]*)([^:\\n]*?)(:)\\s*$",
      "captures": {
        "2": {
          "name": "keyword.control.tag.directive.jotlang"
        },
        "3": {
          "name": "entity.name.tag.jotlang"
        },
        "4": {
          "name": "entity.name.class.component.jotlang"
        },
        "5": {
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        },
        "6": {
          "name": "punctuation.separator.content.jotlang"
        }
      }
    },
    "inline-element": {
      "patterns": [
        {
          "name": "meta.tag.inline.content.jotlang",
          "begin": "(/>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)([^:\\n]*?)(:)",
          "end": "(</)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.tag.inline.jotlang"
            },
            "2": {
              "patterns": [
                {
                  "include": "#tag-name-with-variants"
                }
              ]
            },
            "3": {
              "patterns": [
                {
                  "include": "#attributes"
                }
              ]
            },
            "4": {
              "name": "punctuation.separator.content.jotlang"
            }
          },
          "endCaptures": {
            "1": {
              "name": "keyword.control.tag.inline.jotlang"
            }
          },
          "patterns": [
            {
              "include": "#content-line"
            }
          ]
        }
      ]
    },
    "void-element": {
      "name": "meta.tag.void.jotlang",
      "begin": "^(\\s*)(!>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)(?=\\s*(\\[|$))",
      "end": "(?<=\\])|(?<=[a-zA-Z_0-9])\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.void.jotlang"
        },
        "3": {
          "patterns": [
            {
              "include": "#tag-name-with-variants"
            }
          ]
        }
      },
      "patterns": [
        {
          "include": "#attributes"
        }
      ]
    },
    "tag-name-with-variants": {
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)((?:\\.[a-zA-Z0-9_]+)+)",
          "captures": {
            "1": {
              "name": "entity.name.tag.jotlang"
            },
            "2": {
              "patterns": [
                {
                  "match": "(\\.)([a-zA-Z0-9_]+)",
                  "captures": {
                    "1": {
                      "name": "punctuation.definition.variant.jotlang"
                    },
                    "2": {
                      "name": "entity.other.attribute-name.variant.jotlang"
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "entity.name.tag.jotlang"
        }
      ]
    },
    "block-open": {
      "patterns": [
        {
          "name": "meta.tag.block.same-line.jotlang",
          "begin": "^(\\s*)(>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)([^:\\n]*?)(:)(?=.*\\S.*<\\s*$)",
          "end": "(<)\\s*$",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.tag.jotlang"
            },
            "3": {
              "patterns": [
                {
                  "include": "#tag-name-with-variants"
                }
              ]
            },
            "4": {
              "patterns": [
                {
                  "include": "#attributes"
                }
              ]
            },
            "5": {
              "name": "punctuation.separator.content.jotlang"
            }
          },
          "endCaptures": {
            "1": {
              "name": "keyword.control.tag.jotlang"
            }
          },
          "patterns": [
            {
              "include": "#inline-element"
            },
            {
              "include": "#content-line"
            }
          ]
        },
        {
          "name": "meta.tag.block.multi-line.open.jotlang",
          "begin": "^(\\s*)(>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)",
          "end": "(:)\\s*$",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.tag.jotlang"
            },
            "3": {
              "patterns": [
                {
                  "include": "#tag-name-with-variants"
                }
              ]
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.separator.content.jotlang"
            }
          },
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        }
      ]
    },
    "block-close": {
      "name": "meta.tag.close.jotlang",
      "match": "^\\s*(<)\\s*([a-zA-Z_][a-zA-Z0-9_]*)?\\s*$",
      "captures": {
        "1": {
          "name": "keyword.control.tag.close.jotlang"
        },
        "2": {
          "name": "entity.name.tag.jotlang"
        }
      }
    },
    "control-flow": {
      "name": "meta.control-flow.jotlang",
      "begin": "^(\\s*)(~)\\s+(for|while|if|elif|else)\\b",
      "end": "$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.flow.jotlang"
        },
        "3": {
          "name": "keyword.control.flow.jotlang"
        }
      },
      "patterns": [
        {
          "include": "#expression-content"
        }
      ]
    },
    "control-flow-close": {
      "name": "meta.control-flow.close.jotlang",
      "match": "^\\s*(~<)\\s*$",
      "captures": {
        "1": {
          "name": "keyword.control.flow.jotlang"
        }
      }
    },
    "sibling-marker": {
      "name": "meta.sibling.jotlang",
      "begin": "^(\\s*)(-)(\\s+)",
      "end": "$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.list.jotlang"
        }
      },
      "patterns": [
        {
          "include": "#attributes"
        },
        {
          "include": "#content-line"
        }
      ]
    },
    "fenced-code": {
      "comment": "Fenced code blocks with language injection. We provide specific rules for common languages (typescript, javascript, python, etc.) and fall back to an opaque block for unknown language tags.",
      "patterns": [
        {
          "include": "#fenced-code-typescript"
        },
        {
          "include": "#fenced-code-javascript"
        },
        {
          "include": "#fenced-code-python"
        },
        {
          "include": "#fenced-code-rust"
        },
        {
          "include": "#fenced-code-html"
        },
        {
          "include": "#fenced-code-css"
        },
        {
          "include": "#fenced-code-json"
        },
        {
          "include": "#fenced-code-jotl"
        },
        {
          "include": "#fenced-code-shell"
        },
        {
          "include": "#fenced-code-plain"
        }
      ]
    },
    "fenced-code-typescript": {
      "begin": "^(\\s*)(```)(typescript|ts)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "fenced-code-javascript": {
      "begin": "^(\\s*)(```)(javascript|js)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "fenced-code-python": {
      "begin": "^(\\s*)(```)(python|py)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.python",
      "patterns": [
        {
          "include": "source.python"
        }
      ]
    },
    "fenced-code-rust": {
      "begin": "^(\\s*)(```)(rust|rs)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.rust",
      "patterns": [
        {
          "include": "source.rust"
        }
      ]
    },
    "fenced-code-html": {
      "begin": "^(\\s*)(```)(html)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.html",
      "patterns": [
        {
          "include": "text.html.basic"
        }
      ]
    },
    "fenced-code-css": {
      "begin": "^(\\s*)(```)(css)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "fenced-code-json": {
      "begin": "^(\\s*)(```)(json)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.json",
      "patterns": [
        {
          "include": "source.json"
        }
      ]
    },
    "fenced-code-jotl": {
      "comment": "Nested JOTL inside a fenced block \u2014 useful for doc examples. Include self to highlight recursively.",
      "begin": "^(\\s*)(```)(jotl)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.jotlang",
      "patterns": [
        {
          "include": "source.jotlang"
        }
      ]
    },
    "fenced-code-shell": {
      "begin": "^(\\s*)(```)(shell|bash|sh|zsh)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "contentName": "meta.embedded.block.shellscript",
      "patterns": [
        {
          "include": "source.shell"
        }
      ]
    },
    "fenced-code-plain": {
      "comment": "Fallback for fenced blocks with unknown or missing language tags. Opaque \u2014 contents are not parsed.",
      "begin": "^(\\s*)(```)([a-zA-Z0-9_-]*)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jotlang"
        },
        "3": {
          "name": "fenced_code.block.language.jotlang"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jotlang"
        }
      },
      "name": "markup.fenced_code.block.jotlang",
      "patterns": [
        {
          "match": "^.*$",
          "name": "markup.raw.block.jotlang"
        }
      ]
    },
    "attributes": {
      "name": "meta.attributes.jotlang",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.attributes.begin.jotlang"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.section.attributes.end.jotlang"
        }
      },
      "patterns": [
        {
          "include": "#responsive-override-explicit"
        },
        {
          "include": "#responsive-override-implicit"
        },
        {
          "name": "meta.attribute.key-value.jotlang",
          "match": "([a-zA-Z_][a-zA-Z0-9_-]*)(=)",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.jotlang"
            },
            "2": {
              "name": "punctuation.separator.key-value.jotlang"
            }
          }
        },
        {
          "name": "entity.other.attribute-name.boolean.jotlang",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b(?![=\\^])"
        },
        {
          "include": "#string"
        },
        {
          "include": "#variable-ref"
        },
        {
          "include": "#handler-ref"
        },
        {
          "include": "#iterator-ref"
        },
        {
          "include": "#expression"
        },
        {
          "include": "#css-length"
        },
        {
          "include": "#number"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#unquoted-identifier"
        },
        {
          "name": "keyword.operator.ternary.jotlang",
          "match": "\\?|:"
        }
      ]
    },
    "responsive-override-explicit": {
      "name": "meta.attribute.responsive.explicit.jotlang",
      "match": "([a-zA-Z_][a-zA-Z0-9_-]*)(\\^)(\\()([0-9]+(?:\\.[0-9]+)?(?:px|rem|em|%|vh|vw|pt))(\\))(=)",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.jotlang"
        },
        "2": {
          "name": "keyword.operator.responsive.jotlang"
        },
        "3": {
          "name": "punctuation.definition.responsive.begin.jotlang"
        },
        "4": {
          "name": "constant.numeric.breakpoint.jotlang"
        },
        "5": {
          "name": "punctuation.definition.responsive.end.jotlang"
        },
        "6": {
          "name": "punctuation.separator.key-value.jotlang"
        }
      }
    },
    "responsive-override-implicit": {
      "name": "meta.attribute.responsive.implicit.jotlang",
      "match": "(\\^)(\\()([0-9]+(?:\\.[0-9]+)?(?:px|rem|em|%|vh|vw|pt))(\\))(=)",
      "captures": {
        "1": {
          "name": "keyword.operator.responsive.jotlang"
        },
        "2": {
          "name": "punctuation.definition.responsive.begin.jotlang"
        },
        "3": {
          "name": "constant.numeric.breakpoint.jotlang"
        },
        "4": {
          "name": "punctuation.definition.responsive.end.jotlang"
        },
        "5": {
          "name": "punctuation.separator.key-value.jotlang"
        }
      }
    },
    "css-length": {
      "name": "constant.numeric.length.jotlang",
      "match": "\\b[0-9]+(?:\\.[0-9]+)?(?:px|rem|em|%|vh|vw|pt)\\b"
    },
    "boolean-literal": {
      "name": "constant.language.boolean.jotlang",
      "match": "\\b(true|false)\\b"
    },
    "unquoted-identifier": {
