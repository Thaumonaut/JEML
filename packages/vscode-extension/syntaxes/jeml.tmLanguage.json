{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JEML",
  "scopeName": "source.jeml",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#script-directive"
    },
    {
      "include": "#style-directive"
    },
    {
      "include": "#directive-close"
    },
    {
      "include": "#directive-open"
    },
    {
      "include": "#void-element"
    },
    {
      "include": "#inline-element"
    },
    {
      "include": "#control-flow-close"
    },
    {
      "include": "#control-flow"
    },
    {
      "include": "#block-close"
    },
    {
      "include": "#block-open"
    },
    {
      "include": "#fenced-code"
    },
    {
      "include": "#sibling-marker"
    },
    {
      "include": "#content-line"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.jeml",
          "begin": "%\\{",
          "end": "%\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.jeml"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.jeml"
            }
          }
        },
        {
          "name": "comment.line.percent.jeml",
          "begin": "%",
          "end": "$",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.jeml"
            }
          }
        }
      ]
    },
    "script-directive": {
      "comment": "Embed TypeScript/JavaScript highlighting inside >> script [...] : { ... } <<. The opening brace must be the last non-whitespace on its line. The closing brace must be at column 0 (unindented) \u2014 script bodies are always indented, so a }-at-column-0 is unambiguously the script's close.",
      "begin": "^(\\s*)(>>)\\s+(script)\\b([^:\\n]*?)(:)\\s*(\\{)\\s*$",
      "end": "^(\\})\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.directive.jeml"
        },
        "3": {
          "name": "entity.name.tag.jeml"
        },
        "4": {
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        },
        "5": {
          "name": "punctuation.separator.content.jeml"
        },
        "6": {
          "name": "punctuation.section.embedded.begin.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.jeml"
        }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "style-directive": {
      "comment": "Embed CSS highlighting inside >> style [type=css]: { ... } <<. Same constraint as script-directive \u2014 the closing } must be at column 0.",
      "begin": "^(\\s*)(>>)\\s+(style)\\b([^:\\n]*?)(:)\\s*(\\{)\\s*$",
      "end": "^(\\})\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.directive.jeml"
        },
        "3": {
          "name": "entity.name.tag.jeml"
        },
        "4": {
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        },
        "5": {
          "name": "punctuation.separator.content.jeml"
        },
        "6": {
          "name": "punctuation.section.embedded.begin.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.jeml"
        }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "inline-element": {
      "patterns": [
        {
          "name": "meta.tag.inline.content.jeml",
          "begin": "(/>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)([^:\\n]*?)(:)",
          "end": "(</)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.tag.inline.jeml"
            },
            "2": {
              "patterns": [
                {
                  "include": "#tag-name-with-variants"
                }
              ]
            },
            "3": {
              "patterns": [
                {
                  "include": "#attributes"
                }
              ]
            },
            "4": {
              "name": "punctuation.separator.content.jeml"
            }
          },
          "endCaptures": {
            "1": {
              "name": "keyword.control.tag.inline.jeml"
            }
          },
          "patterns": [
            {
              "include": "#content-line"
            }
          ]
        }
      ]
    },
    "void-element": {
      "name": "meta.tag.void.jeml",
      "begin": "^(\\s*)(!>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)(?=\\s*(\\[|$))",
      "end": "(?<=\\])|(?<=[a-zA-Z_0-9])\\s*$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.tag.void.jeml"
        },
        "3": {
          "patterns": [
            {
              "include": "#tag-name-with-variants"
            }
          ]
        }
      },
      "patterns": [
        {
          "include": "#attributes"
        }
      ]
    },
    "tag-name-with-variants": {
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)((?:\\.[a-zA-Z0-9_]+)+)",
          "captures": {
            "1": {
              "name": "entity.name.tag.jeml"
            },
            "2": {
              "patterns": [
                {
                  "match": "(\\.)([a-zA-Z0-9_]+)",
                  "captures": {
                    "1": {
                      "name": "punctuation.definition.variant.jeml"
                    },
                    "2": {
                      "name": "entity.other.attribute-name.variant.jeml"
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "entity.name.tag.jeml"
        }
      ]
    },
    "block-open": {
      "patterns": [
        {
          "name": "meta.tag.block.same-line.jeml",
          "begin": "^(\\s*)(>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)([^:\\n]*?)(:)(?=.*\\S.*<\\s*$)",
          "end": "(<)\\s*$",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.tag.jeml"
            },
            "3": {
              "patterns": [
                {
                  "include": "#tag-name-with-variants"
                }
              ]
            },
            "4": {
              "patterns": [
                {
                  "include": "#attributes"
                }
              ]
            },
            "5": {
              "name": "punctuation.separator.content.jeml"
            }
          },
          "endCaptures": {
            "1": {
              "name": "keyword.control.tag.jeml"
            }
          },
          "patterns": [
            {
              "include": "#inline-element"
            },
            {
              "include": "#content-line"
            }
          ]
        },
        {
          "name": "meta.tag.block.multi-line.open.jeml",
          "begin": "^(\\s*)(>)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z0-9_]+)*)",
          "end": "(:)\\s*$",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.tag.jeml"
            },
            "3": {
              "patterns": [
                {
                  "include": "#tag-name-with-variants"
                }
              ]
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.separator.content.jeml"
            }
          },
          "patterns": [
            {
              "include": "#attributes"
            }
          ]
        }
      ]
    },
    "block-close": {
      "name": "meta.tag.close.jeml",
      "match": "^\\s*(<)\\s*([a-zA-Z_][a-zA-Z0-9_]*)?\\s*$",
      "captures": {
        "1": {
          "name": "keyword.control.tag.close.jeml"
        },
        "2": {
          "name": "entity.name.tag.jeml"
        }
      }
    },
    "control-flow": {
      "name": "meta.control-flow.jeml",
      "begin": "^(\\s*)(~)\\s+(for|if|else\\s+if|else)\\b",
      "end": "$",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.flow.jeml"
        },
        "3": {
          "name": "keyword.control.flow.jeml"
        }
      },
      "patterns": [
        {
          "include": "#expression-content"
        }
      ]
    },
    "control-flow-close": {
      "name": "meta.control-flow.close.jeml",
      "match": "^\\s*(~<)\\s*$",
      "captures": {
        "1": {
          "name": "keyword.control.flow.jeml"
        }
      }
    },
    "sibling-marker": {
      "name": "meta.sibling.jeml",
      "begin": "^(\\s*)(-)(\\s+)",
      "end": "$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.list.jeml"
        }
      },
      "patterns": [
        {
          "include": "#attributes"
        },
        {
          "include": "#content-line"
        }
      ]
    },
    "fenced-code": {
      "comment": "Fenced code blocks with language injection. We provide specific rules for common languages (typescript, javascript, python, etc.) and fall back to an opaque block for unknown language tags.",
      "patterns": [
        {
          "include": "#fenced-code-typescript"
        },
        {
          "include": "#fenced-code-javascript"
        },
        {
          "include": "#fenced-code-python"
        },
        {
          "include": "#fenced-code-rust"
        },
        {
          "include": "#fenced-code-html"
        },
        {
          "include": "#fenced-code-css"
        },
        {
          "include": "#fenced-code-json"
        },
        {
          "include": "#fenced-code-jeml"
        },
        {
          "include": "#fenced-code-shell"
        },
        {
          "include": "#fenced-code-plain"
        }
      ]
    },
    "fenced-code-typescript": {
      "begin": "^(\\s*)(```)(typescript|ts)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "fenced-code-javascript": {
      "begin": "^(\\s*)(```)(javascript|js)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "fenced-code-python": {
      "begin": "^(\\s*)(```)(python|py)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.python",
      "patterns": [
        {
          "include": "source.python"
        }
      ]
    },
    "fenced-code-rust": {
      "begin": "^(\\s*)(```)(rust|rs)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.rust",
      "patterns": [
        {
          "include": "source.rust"
        }
      ]
    },
    "fenced-code-html": {
      "begin": "^(\\s*)(```)(html)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.html",
      "patterns": [
        {
          "include": "text.html.basic"
        }
      ]
    },
    "fenced-code-css": {
      "begin": "^(\\s*)(```)(css)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "fenced-code-json": {
      "begin": "^(\\s*)(```)(json)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.json",
      "patterns": [
        {
          "include": "source.json"
        }
      ]
    },
    "fenced-code-jeml": {
      "comment": "Nested JEML inside a fenced block \u2014 useful for doc examples. Include self to highlight recursively.",
      "begin": "^(\\s*)(```)(jeml)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.jeml",
      "patterns": [
        {
          "include": "source.jeml"
        }
      ]
    },
    "fenced-code-shell": {
      "begin": "^(\\s*)(```)(shell|bash|sh|zsh)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "contentName": "meta.embedded.block.shellscript",
      "patterns": [
        {
          "include": "source.shell"
        }
      ]
    },
    "fenced-code-plain": {
      "comment": "Fallback for fenced blocks with unknown or missing language tags. Opaque \u2014 contents are not parsed.",
      "begin": "^(\\s*)(```)([a-zA-Z0-9_-]*)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.markdown.jeml"
        },
        "3": {
          "name": "fenced_code.block.language.jeml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.markdown.jeml"
        }
      },
      "name": "markup.fenced_code.block.jeml",
      "patterns": [
        {
          "match": "^.*$",
          "name": "markup.raw.block.jeml"
        }
      ]
    },
    "attributes": {
      "name": "meta.attributes.jeml",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.attributes.begin.jeml"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.section.attributes.end.jeml"
        }
      },
      "patterns": [
        {
          "include": "#responsive-override-explicit"
        },
        {
          "include": "#responsive-override-implicit"
        },
        {
          "name": "meta.attribute.key-value.jeml",
          "match": "([a-zA-Z_][a-zA-Z0-9_-]*)(=)",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.jeml"
            },
            "2": {
              "name": "punctuation.separator.key-value.jeml"
            }
          }
        },
        {
          "name": "entity.other.attribute-name.boolean.jeml",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b(?![=\\^])"
        },
        {
          "include": "#string"
        },
        {
          "include": "#variable-ref"
        },
        {
          "include": "#handler-ref"
        },
        {
          "include": "#iterator-ref"
        },
        {
          "include": "#expression"
        },
        {
          "include": "#css-length"
        },
        {
          "include": "#number"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#unquoted-identifier"
        },
        {
          "name": "keyword.operator.ternary.jeml",
          "match": "\\?|:"
        }
      ]
    },
    "responsive-override-explicit": {
      "name": "meta.attribute.responsive.explicit.jeml",
      "match": "([a-zA-Z_][a-zA-Z0-9_-]*)(\\^)(\\()([0-9]+(?:\\.[0-9]+)?(?:px|rem|em|%|vh|vw|pt))(\\))(=)",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.jeml"
        },
        "2": {
          "name": "keyword.operator.responsive.jeml"
        },
        "3": {
          "name": "punctuation.definition.responsive.begin.jeml"
        },
        "4": {
          "name": "constant.numeric.breakpoint.jeml"
        },
        "5": {
          "name": "punctuation.definition.responsive.end.jeml"
        },
        "6": {
          "name": "punctuation.separator.key-value.jeml"
        }
      }
    },
    "responsive-override-implicit": {
      "name": "meta.attribute.responsive.implicit.jeml",
      "match": "(\\^)(\\()([0-9]+(?:\\.[0-9]+)?(?:px|rem|em|%|vh|vw|pt))(\\))(=)",
      "captures": {
        "1": {
          "name": "keyword.operator.responsive.jeml"
        },
        "2": {
          "name": "punctuation.definition.responsive.begin.jeml"
        },
        "3": {
          "name": "constant.numeric.breakpoint.jeml"
        },
        "4": {
          "name": "punctuation.definition.responsive.end.jeml"
        },
        "5": {
          "name": "punctuation.separator.key-value.jeml"
        }
      }
    },
    "css-length": {
      "name": "constant.numeric.length.jeml",
      "match": "\\b[0-9]+(?:\\.[0-9]+)?(?:px|rem|em|%|vh|vw|pt)\\b"
    },
    "boolean-literal": {
      "name": "constant.language.boolean.jeml",
      "match": "\\b(true|false)\\b"
    },
    "unquoted-identifier": {
      "name": "string.unquoted.jeml",
      "match": "(?<==)([a-zA-Z_][a-zA-Z0-9_-]*)"
    },
    "import-names": {
      "patterns": [
        {
          "name": "meta.import.namespace.jeml",
          "match": "(\\*)\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.namespace.jeml"
            },
            "2": {
              "name": "keyword.control.import.jeml"
            },
            "3": {
              "name": "entity.name.namespace.jeml"
            }
          }
        },
        {
          "name": "meta.import.destructure.jeml",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.destructure.begin.jeml"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.destructure.end.jeml"
            }
          },
          "patterns": [
            {
              "name": "entity.name.import.jeml",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*"
            },
            {
              "name": "punctuation.separator.comma.jeml",
              "match": ","
            }
          ]
        },
        {
          "name": "entity.name.import.default.jeml",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.jeml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jeml",
              "match": "\\\\."
            },
            {
              "include": "#variable-ref"
            },
            {
              "include": "#expression"
            }
          ]
        },
        {
          "name": "string.quoted.single.jeml",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.jeml",
              "match": "\\\\."
            },
            {
              "include": "#variable-ref"
            },
            {
              "include": "#expression"
            }
          ]
        },
        {
          "name": "string.quoted.backtick.jeml",
          "begin": "`",
          "end": "`",
          "patterns": [
