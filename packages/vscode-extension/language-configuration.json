{
  "comments": {
    "lineComment": "%",
    "blockComment": ["%{", "%}"]
  },
  "brackets": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "`", "close": "`" },
    { "open": "%{", "close": "%}" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["**", "**"],
    ["_", "_"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(!>|>)\\s+\\w+.*:\\s*$",
      "end": "^\\s*(<!|<)\\s*\\w*\\s*$"
    }
  }
}
