{
  "name": "solid-jotlang",
  "version": "0.6.0",
  "description": "JOTLANG on top of SolidJS — Vite plugin that compiles .jot files to reactive Solid components.",
  "keywords": [
    "jotlang",
    "jotl",
    "solid",
    "solidjs",
    "vite",
    "vite-plugin",
    "jsx",
    "compiler"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./runtime": {
      "types": "./dist/runtime/helpers.d.ts",
      "import": "./dist/runtime/helpers.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thaumonaut/jotl-project.git",
    "directory": "packages/solid-jotlang"
  },
  "homepage": "https://github.com/Thaumonaut/jotl-project#readme",
  "bugs": {
    "url": "https://github.com/Thaumonaut/jotl-project/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "solid-js": ">=1.8.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "jotlang": "*"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^26.0.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  }
}
