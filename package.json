{
  "name": "jeml",
  "version": "0.4.0",
  "private": true,
  "description": "JEML — Jacob's Easy Markup Language. Monorepo containing compiler, LSP, and tooling.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev -w @jeml/compiler",
    "dev:lsp": "npm run dev -w @jeml/lsp"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Thaumonaut/JEML.git"
  },
  "license": "MIT"
}
