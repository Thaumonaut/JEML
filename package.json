{
  "name": "jotlang-monorepo",
  "version": "0.6.0",
  "private": true,
  "description": "JOTLANG (Jot Object Template Language) — a structured markup language. Monorepo containing the compiler, LSP, Solid integration, and tooling.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev -w jotlang",
    "dev:lsp": "npm run dev -w jotlang-lsp",
    "build:cli": "npm run build:cli -w jotlang",
    "build:playground": "npm run build:playground -w jotlang"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Thaumonaut/JOTL.git"
  },
  "license": "MIT"
}
